configuration {
    modi:                 "drun,filebrowser";
    show-icons:           true;
    display-drun:         "";
    display-run:          "";
    display-filebrowser:  "";
    display-window:       "";
    drun-display-format:  "{name}";
    window-format:        "{w} · {c} · {t}";
}

@import ".config/rofi/gruvbox.rasi"
@import ".config/rofi/fonts.rasi"

* {
    border-colour:               @aqua;
    handle-colour:               @aqua;
    background-colour:           @bg;
    foreground-colour:           @fg;
    alternate-background:        @surface;
    normal-background:           transparent;
    normal-foreground:           @fg;
    urgent-background:           @yellow;
    urgent-foreground:           @bg;
    active-background:           @aqua-soft;
    active-foreground:           @fg;
    selected-normal-background:  @hover;
    selected-normal-foreground:  @fg;
    selected-urgent-background:  @yellow;
    selected-urgent-foreground:  @bg;
    selected-active-background:  @hover;
    selected-active-foreground:  @fg;
    alternate-normal-background: transparent;
    alternate-normal-foreground: @fg;
    alternate-urgent-background: @yellow;
    alternate-urgent-foreground: @bg;
    alternate-active-background: @aqua-soft;
    alternate-active-foreground: @fg;
}

window {
    transparency:     "real";
    location:         center;
    anchor:           center;
    fullscreen:       false;
    width:            340px;
    x-offset:         0px;
    y-offset:         0px;
    enabled:          true;
    margin:           0px;
    padding:          0px;
    border:           0px solid;
    border-radius:    0px;
    border-color:     @border-colour;
    cursor:           "default";
    background-color: transparent;
}

mainbox {
    enabled:          true;
    children:         [ "inputbar", "listview" ];
    spacing:          14px;
    margin:           0px;
    padding:          22px;
    border:           2px solid;
    border-radius:    0px;
    border-color:     @border-soft;
    background-color: @bg;
}

inputbar {
    enabled:          true;
    children:         [ "entry" ];
    spacing:          0px;
    margin:           0px;
    padding:          9px 12px;
    border:           1px solid;
    border-radius:    0px;
    border-color:     @aqua;
    background-color: @surface;
    text-color:       @foreground-colour;
}

textbox-prompt-colon {
    enabled:          false;
    expand:           false;
    str:              "";
    background-color: transparent;
    text-color:       @fg-muted;
}

entry {
    enabled:           true;
    margin:            0px;
    padding:           0px;
    background-color:  transparent;
    text-color:        @foreground-colour;
    cursor:            text;
    placeholder:       "run application...";
    placeholder-color: @fg-muted;
}

num-filtered-rows,
textbox-num-sep,
num-rows,
case-indicator {
    enabled:          true;
    expand:           false;
    background-color: inherit;
    text-color:       inherit;
}

textbox-num-sep {
    str: "/";
}

listview {
    enabled:          true;
    columns:          1;
    lines:            5;
    cycle:            true;
    dynamic:          true;
    scrollbar:        false;
    layout:           vertical;
    reverse:          false;
    fixed-height:     false;
    fixed-columns:    false;
    spacing:          6px;
    margin:           0px;
    padding:          0px;
    border:           0px solid;
    border-radius:    0px;
    border-color:     @border-soft;
    background-color: transparent;
    text-color:       @foreground-colour;
    cursor:           "default";
}

element {
    enabled:          true;
    spacing:          10px;
    margin:           0px;
    padding:          8px 10px;
    border:           1px solid;
    border-radius:    0px;
    border-color:     transparent;
    background-color: transparent;
    text-color:       @foreground-colour;
    cursor:           pointer;
}

element normal.normal {
    background-color: var(normal-background);
    text-color:       var(normal-foreground);
}

element normal.urgent {
    background-color: var(urgent-background);
    text-color:       var(urgent-foreground);
}

element normal.active {
    background-color: var(active-background);
    text-color:       var(active-foreground);
}

element selected.normal {
    border-color:     @hover-border;
    background-color: var(selected-normal-background);
    text-color:       var(selected-normal-foreground);
}

element selected.urgent {
    border-color:     @yellow;
    background-color: var(selected-urgent-background);
    text-color:       var(selected-urgent-foreground);
}

element selected.active {
    border-color:     @hover-border;
    background-color: var(selected-active-background);
    text-color:       var(selected-active-foreground);
}

element alternate.normal {
    background-color: var(alternate-normal-background);
    text-color:       var(alternate-normal-foreground);
}

element alternate.urgent {
    background-color: var(alternate-urgent-background);
    text-color:       var(alternate-urgent-foreground);
}

element alternate.active {
    background-color: var(alternate-active-background);
    text-color:       var(alternate-active-foreground);
}

element-icon {
    size:             20px;
    background-color: transparent;
    text-color:       inherit;
    cursor:           inherit;
}

element-text {
    vertical-align:   0.5;
    horizontal-align: 0.0;
    background-color: transparent;
    text-color:       inherit;
    highlight:        inherit;
    cursor:           inherit;
}

mode-switcher {
    enabled:          true;
    spacing:          10px;
    margin:           0px;
    padding:          0px;
    border:           0px solid;
    border-radius:    0px;
    border-color:     @border-colour;
    background-color: transparent;
    text-color:       @foreground-colour;
}

button {
    padding:          6px 10px;
    border:           1px solid;
    border-radius:    0px;
    border-color:     @border-soft;
    background-color: @surface;
    text-color:       inherit;
    cursor:           pointer;
}

button selected {
    border-color:     @hover-border;
    background-color: @hover;
    text-color:       @fg;
}

message {
    enabled:          true;
    margin:           0px;
    padding:          0px;
    border:           0px solid;
    border-radius:    0px;
    border-color:     @border-colour;
    background-color: transparent;
    text-color:       @foreground-colour;
}

textbox {
    padding:           8px 10px;
    border:            1px solid;
    border-radius:     0px;
    border-color:      @border-soft;
    background-color:  @surface;
    text-color:        @foreground-colour;
    vertical-align:    0.5;
    horizontal-align:  0.0;
    highlight:         none;
    placeholder-color: @fg-muted;
    blink:             true;
    markup:            true;
}

error-message {
    padding:          10px;
    border:           1px solid;
    border-radius:    0px;
    border-color:     @yellow;
    background-color: @background-colour;
    text-color:       @foreground-colour;
}
